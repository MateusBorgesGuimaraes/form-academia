---
import type { HTMLAttributes } from "astro/types";
import { cn } from "../../lib/utils";

interface Props extends HTMLAttributes<"button"> {
    variants?: "yellow" | "dark" | "outline";
    size?: "md" | "sm";
}

const {
    variants = "yellow",
    size = "md",
    class: className,
    ...rest
} = Astro.props;
---

<button
    class={cn(
        "inline-flex items-center justify-center px-6 py-3 uppercase transition",

        variants === "yellow" && "bg-yellow text-black hover:bg-yellow-hover",

        variants === "dark" && "bg-black text-yellow hover:bg-black-mid",

        variants === "outline" &&
            "border border-border-sub text-text-subtle hover:text-text-primary",
    )}
    {...rest}
>
    <slot />
</button>
