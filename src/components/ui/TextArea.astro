---
interface Props {
    title: string;
    placeholder?: string;
}

const { title, placeholder } = Astro.props;
---

<div class="flex flex-col gap-1 w-full">
    <label class="text-sm text-text-muted uppercase" for={title}>{title}</label>
    <textarea
        class="bg-black-mid placeholder:text-text-muted/40 border border-border py-2 px-3 w-full placeholder:text-xs placeholder:uppercase focus:border-yellow focus:outline-none h-45 resize-none"
        placeholder={placeholder}
        id={title}></textarea>
</div>
