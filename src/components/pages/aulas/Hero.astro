<section>
    <div class="wrapper py-12 flex gap-6 justify-between">
        <div>
            <span class="eyebrow">Grade de aulas</span>
            <h1 class="title-display">
                Encontre <br />
                sua <span class="text-yellow italic">aula.</span>
            </h1>

            <p class="max-w-100 mt-4">
                Mais de 30 aulas semanais distribuídas em três studios. Do
                iniciante ao avançado, sempre com instrutores certificados.
            </p>
        </div>

        <ul class="flex flex-col gap-3">
            <li class="bg-black-mid flex items-center gap-6 px-12 py-6">
                <h2 class="font-display text-3xl text-text-primary">30+</h2>
                <p class="text-sm">Aulas por semana em 3 studios</p>
            </li>
            <li class="bg-black-mid flex items-center gap-6 px-12 py-6">
                <h2 class="font-display text-3xl text-text-primary">6</h2>
                <p class="text-sm">Modalidades disponíveis</p>
            </li>
            <li class="bg-black-mid flex items-center gap-6 px-12 py-6">
                <h2 class="font-display text-3xl text-text-primary">12</h2>
                <p class="text-sm">Instrutores certificados</p>
            </li>
        </ul>
    </div>
</section>
