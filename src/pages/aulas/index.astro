---
import { getCollection } from "astro:content";
import Hero from "../../components/pages/aulas/Hero.astro";
import Base from "../../layouts/Base.astro";
import AulasFiltro from "../../components/pages/aulas/AulasFiltro";
const aulas = await getCollection("aulas");
---

<Base title="aulas">
    <Hero />
    <AulasFiltro client:load aulas={aulas} />
</Base>;
